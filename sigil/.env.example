# Root env for local development

# ============ Blockchain Configuration ============
# Contracts Deployment
PRIVATE_KEY=                                    # Your wallet private key (DO NOT COMMIT!)
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc  # Alias for compatibility
ARBISCAN_API_KEY=                               # Get from https://arbiscan.io/myapikey
ETHERSCAN_API_KEY=                              # Alias for ARBISCAN_API_KEY

# ============ Backend Configuration ============
ANTHROPIC_API_KEY=                              # Your Anthropic API key for AI agent
PORT=3001                                        # Backend server port
NODE_ENV=development                             # development | production

# ============ Optional: Additional Networks ============
# ETHEREUM_MAINNET_RPC=
# ARBITRUM_MAINNET_RPC=
# POLYGON_MAINNET_RPC=
