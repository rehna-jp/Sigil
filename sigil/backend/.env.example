# Groq API Key for AI decomposition (FREE - get from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Wallet private key for signing transactions
PRIVATE_KEY=your_private_key_here

# Arbitrum Sepolia RPC URL
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Server port
PORT=3001

# Auto-start keeper service on backend startup
AUTO_START_KEEPER=false

# Keeper configuration (optional)
KEEPER_POLLING_INTERVAL=12000
KEEPER_BATCH_SIZE=50
KEEPER_MAX_GAS_PRICE=0.1
