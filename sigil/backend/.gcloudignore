# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore

.gcloudignore
.git
.gitignore

# Node modules (will be installed in container)
node_modules/
npm-debug.log*

# Build output (will be built in container)
dist/

# Environment files
.env
.env.*
!.env.example

# Documentation
*.md
!README.md

# Test files
test/
*.test.ts
*.spec.ts

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
tmp/
